# Custom git aliases (oh-my-zsh git plugin provides: g, gco, gm, gs)
# Keeping only unique aliases that differ from oh-my-zsh defaults

# Commit without -v flag (oh-my-zsh's gca adds --verbose)
alias gci="git commit"

# Log (oh-my-zsh's gl is 'git pull', user version is 'git log' - different!)
alias gl="git log"
